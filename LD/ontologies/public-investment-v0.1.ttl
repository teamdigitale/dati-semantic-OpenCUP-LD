<https://w3id.org/italia/PublicInvestment/onto/PublicInvestment> rdf:type owl:Ontology ;				
				owl:versionIRI <https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/1.0> ;
				owl:versionInfo "Versione 1.0"@it , 
								"Version 1.0"@en ;
				dct:identifier "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment" ;
				dct:accrualPeriodicity <http://publications.europa.eu/resource/authority/frequency/IRREG> ;
				dct:language <http://publications.europa.eu/resource/authority/language/ITA> , <http://publications.europa.eu/resource/authority/language/ENG> ;
				dcat:theme <http://publications.europa.eu/resource/authority/data-theme/ECON> , <http://publications.europa.eu/resource/authority/data-theme/GOVE> ;
				dct:creator <https://w3id.org/italia/data/public-organization/PCM-DIPE> , <https://w3id.org/italia/data/public-organization/ISTAT> ; 
				dct:publisher <https://w3id.org/italia/data/public-organization/PCM-DIPE> ;
				dct:rightsHolder <https://w3id.org/italia/data/public-organization/PCM-DIPE>; 
				dct:issued "2026-07-08"^^xsd:date ;
				dct:modified "2026-07-08"^^xsd:date ;
				dct:temporal "Dal 2026" ;
				dct:subject <https://w3id.org/italia/PublicInvestment/onto/PublicInvestment> ;
				dct:title "Public Investment Ontology"@en , 
						  "Ontologia degli Investimenti Pubblici"@it ;		  
				dct:description "L’ontologia è il prodotto dell'analisi semantica del Codice Unico di Progetto (CUP) e del patrimonio informativo del portale OpenCUP. È sviluppata dal Dipartimento per la programmazione e il coordinamento della politica economica (DIPE) della Presidenza del Consiglio dei Ministri, con la semantic stewardship dell'ISTAT e in coordinamento con il Dipartimento per la Trasformazione Digitale (DTD), nell'ambito dell'Impegno C6 del 6° Piano d'Azione Nazionale per il Governo Aperto (OGP) 2024–2026. È allineata alla rete OntoPiA ed è pubblicata nel Catalogo Nazionale dei dati semantici (schema.gov.it)."@it , 
								"This ontology is the product of the semantic analysis of the Unique Project Code (CUP) and of the information assets of the OpenCUP portal. It is developed by the Department for Programming and Coordination of Economic Policy (DIPE) of the Presidency of the Council of Ministers, with the semantic stewardship of ISTAT and in coordination with the Department for Digital Transformation (DTD), within commitment C6 of the 6th National Action Plan for the Open Government Partnership (OGP) 2024–2026. It is aligned with the OntoPiA network and published in the National Catalog of Semantic Data (schema.gov.it)."@en ;                                   
				rdfs:comment "L’ontologia è il prodotto dell'analisi semantica del Codice Unico di Progetto (CUP) e del patrimonio informativo del portale OpenCUP. È sviluppata dal Dipartimento per la programmazione e il coordinamento della politica economica (DIPE) della Presidenza del Consiglio dei Ministri, con la semantic stewardship dell'ISTAT e in coordinamento con il Dipartimento per la Trasformazione Digitale (DTD), nell'ambito dell'Impegno C6 del 6° Piano d'Azione Nazionale per il Governo Aperto (OGP) 2024–2026. È allineata alla rete OntoPiA ed è pubblicata nel Catalogo Nazionale dei dati semantici (schema.gov.it)."@it ,
							 "This ontology is the product of the semantic analysis of the Unique Project Code (CUP) and of the information assets of the OpenCUP portal. It is developed by the Department for Programming and Coordination of Economic Policy (DIPE) of the Presidency of the Council of Ministers, with the semantic stewardship of ISTAT and in coordination with the Department for Digital Transformation (DTD), within commitment C6 of the 6th National Action Plan for the Open Government Partnership (OGP) 2024–2026. It is aligned with the OntoPiA network and published in the National Catalog of Semantic Data (schema.gov.it)."@en ;                                    
				rdfs:label "Public Investment Ontology."@en , 
						   "Ontologia degli Investimenti Pubblici"@it ;                               
				dcat:contactPoint <https://w3id.org/italia/data/contact-point/PCM-DIPE> ;
				dcat:keyword "Investimenti Pubblici"@it , "OpenCUP"@it,
							 "Public Investment"@en , "OpenCUP"@en ;
				admsapit:acronym "PI" ;
				admsapit:hasContributor <https://w3id.org/italia/data/public-organization/PCM-DIPE> , <https://w3id.org/italia/data/public-organization/ISTAT>;
				admsapit:hasFormalityLevel admsapit:Formal ;
				admsapit:hasKeyClass :Codice_unico_di_progetto ,
									 :Intervento_di_investimento_pubblico ;					 
				admsapit:hasOntologyLanguage admsapit:OWL ;
				admsapit:hasSemanticAssetDistribution <https://w3id.org/italia/data/distribution/PI-JSON-LD> ,
													  <https://w3id.org/italia/data/distribution/PI-RDF-TURTLE> ,
													  <https://w3id.org/italia/data/distribution/PI-RDF-XML> ;									  
				admsapit:hasTask admsapit:AnnotationTask ,
								 admsapit:QueryFormulationTask ,
								 admsapit:SearchTask ;				 
				admsapit:last <https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/1.0> ;
				admsapit:officialURI "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment"^^xsd:anyURI ;
				admsapit:prefix "pi" ;
				admsapit:semanticAssetInUse <https://w3id.org/italia/data/project/NDC> ;
				admsapit:status "catalogued" , "published" ;
				admsapit:target "Pubbliche Amministrazioni" ;
				admsapit:type admsapit:DomainOntology .


   
