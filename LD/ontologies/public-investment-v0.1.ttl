  rdfs:subClassOf ocup:Tipologia_di_intervento
] .


[ rdf:type owl:Restriction ;
  owl:onProperty ocup:ha_stato_di_cup ;
  owl:someValuesFrom [ rdf:type owl:Restriction ;
                       owl:onProperty [ owl:inverseOf ocup:ha_cup_provvisorio_collegato
                                      ] ;
                       owl:someValuesFrom owl:Thing
                     ] ;
  rdfs:subClassOf ocup:Stato_provvisorio_di_cup
] .


[ rdf:type owl:Restriction ;
  owl:onProperty RO:holdsRoleInTime ;
  owl:someValuesFrom ocup:Soggetto_concentratore ;
  rdfs:subClassOf COV:PublicOrganization
] .


[ rdf:type owl:Restriction ;
  owl:onProperty [ owl:inverseOf RO:holdsRoleInTime
                 ] ;
  owl:someValuesFrom [ rdf:type owl:Restriction ;
                       owl:onProperty COV:hasSupportUnit ;
                       owl:someValuesFrom [ rdf:type owl:Restriction ;
                                            owl:onProperty COV:holdEmployment ;
                                            owl:someValuesFrom ocup:Utente_richiedente_cup
                                          ]
                     ] ;
  rdfs:subClassOf ocup:Soggetto_richiedente_cup
] .


[ rdf:type owl:Restriction ;
  owl:onProperty [ owl:inverseOf RO:holdsRoleInTime
                 ] ;
  owl:someValuesFrom [ rdf:type owl:Restriction ;
                       owl:onProperty COV:hasSupportUnit ;
                       owl:someValuesFrom [ rdf:type owl:Restriction ;
                                            owl:onProperty COV:holdEmployment ;
                                            owl:someValuesFrom ocup:Utente_riferimento_cup
                                          ]
                     ] ;
  rdfs:subClassOf ocup:Soggetto_titolare_progetto_investimento
] .


[ rdf:type owl:Restriction ;
  owl:onProperty [ owl:inverseOf L0:directlyPrecedes
                 ] ;
  owl:someValuesFrom ocup:Stato_cancellato_di_cup ;
  rdfs:subClassOf [ rdf:type owl:Class ;
                    owl:unionOf ( ocup:Stato_completo_di_cup
                                  ocup:Stato_provvisorio_di_cup
                                )
                  ]
] .


[ rdf:type owl:Restriction ;
  owl:onProperty [ owl:inverseOf L0:directlyPrecedes
                 ] ;
  owl:someValuesFrom [ rdf:type owl:Class ;
                       owl:unionOf ( ocup:Stato_chiuso_di_cup
                                     ocup:Stato_revocato_di_cup
                                   )
                     ] ;
  rdfs:subClassOf ocup:Stato_attivo_di_cup
] .


