[ rdf:type owl:Class ;
  owl:unionOf ( ocup:Stato_cancellato_di_cup
                ocup:Stato_chiuso_di_cup
                ocup:Stato_revocato_di_cup
              ) ;
  owl:equivalentClass [ rdf:type owl:Restriction ;
                        owl:onProperty [ owl:inverseOf L0:hasLastMember
                                       ] ;
                        owl:someValuesFrom ocup:Storia_di_cup
                      ]
] .


[ owl:intersectionOf ( COV:Organization
                       [ rdf:type owl:Restriction ;
                         owl:onProperty [ owl:inverseOf ocup:ha_beneficiario_contributo
                                        ] ;
                         owl:someValuesFrom owl:Thing
                       ]
                     ) ;
  rdf:type owl:Class ;
  rdfs:subClassOf [ rdf:type owl:Restriction ;
                    owl:onProperty COV:hasActivityType ;
                    owl:someValuesFrom owl:Thing
                  ]
] .


[ rdf:type owl:Class ;
  owl:unionOf ( ocup:Acquisto_di_beni
                [ rdf:type owl:Class ;
                  owl:unionOf ( ocup:Acquisto_o_realizzazione_di_servizi
                                ocup:Realizzazione_di_lavori_pubblici
                              )
                ]
              ) ;
  rdfs:subClassOf [ rdf:type owl:Restriction ;
                    owl:onProperty ocup:partenariato_pubblico-privato_e_forme_speciali_partenariato ;
                    owl:someValuesFrom rdfs:Literal
                  ]
] .


[ rdf:type owl:Class ;
  owl:unionOf ( ocup:Acquisto_o_realizzazione_di_servizi
                ocup:Realizzazione_di_lavori_pubblici
              ) ;
  rdfs:subClassOf [ rdf:type owl:Restriction ;
                    owl:onProperty ocup:finanza_di_progetto ;
                    owl:someValuesFrom rdfs:Literal
                  ]
] .


[ rdf:type owl:Class ;
  owl:unionOf ( ocup:Acquisto_o_realizzazione_di_servizi
                ocup:Realizzazione_di_lavori_pubblici
              ) ;
  rdfs:subClassOf [ rdf:type owl:Restriction ;
                    owl:onProperty ocup:tipologia_operazione_partenariato ;
                    owl:someValuesFrom rdfs:Literal
                  ]
] .


[ rdf:type owl:Class ;
  owl:unionOf ( ocup:Atto_amministrativo_progetto_cumulativo
                ocup:Atto_autorizzazione_cup
                ocup:Atto_cancellazione_cup
                ocup:Atto_chiusura_cup
                ocup:Atto_delega_richiesta_cup
                ocup:Atto_finanziamento_investimento_pubblico
                ocup:Atto_generazione_cup
                ocup:Atto_modifica_cup
                ocup:Atto_revoca_cup
                ocup:Atto_revoca_delega_richiesta_cup
              ) ;
  rdfs:subClassOf ocup:Atto
] .


[ rdf:type owl:Class ;
  owl:unionOf ( ocup:Cup_collegato_a_master
                ocup:Cup_cumulativo
                ocup:Cup_master
              ) ;
  rdfs:subClassOf ocup:Codice_unico_di_progetto
] .


[ rdf:type owl:Class ;
  owl:unionOf ( ocup:Soggetto_concentratore
                ocup:Soggetto_titolare_progetto_investimento
              ) ;
  rdfs:subClassOf [ rdf:type owl:Restriction ;
                    owl:onProperty [ owl:inverseOf RO:holdsRoleInTime
                                   ] ;
                    owl:someValuesFrom ocup:Soggetto_accreditato_sistema_cup
                  ]
] .


[ rdf:type owl:Class ;
  owl:unionOf ( ocup:Stato_attivo_di_cup
                ocup:Stato_cancellato_di_cup
                ocup:Stato_chiuso_di_cup
                ocup:Stato_coerente_programma_spesa_di_cup
                ocup:Stato_corretto_di_cup
                ocup:Stato_provvisorio_di_cup
                ocup:Stato_revocato_di_cup
                ocup:Stato_valido_di_Cup
              ) ;
  rdfs:subClassOf ocup:Stato_di_cup
] .


[ rdf:type owl:Class ;
  owl:unionOf ( ocup:Stato_di_coerenza_di_atto_di_finanziamento
                ocup:Stato_di_correttezza_di_atto_di_finanziamento
                ocup:Stato_di_emanazione_di_atto_di_finanziamento
              ) ;
  rdfs:subClassOf ocup:Stato_di_atto_di_finanziamento
] .


[ rdf:type owl:Class ;
  owl:unionOf ( [ rdf:type owl:Class ;
                  owl:oneOf ( ocup:acquisto_o_realizzazione_corso_di_formazione
                            )
                ]
                [ rdf:type owl:Class ;
                  owl:oneOf ( ocup:acquisto_o_realizzazione_progetto_di_ricerca
                            )
